{
  "name": "babu-ch/phpcs-aaa",
  "description": "PHP_CodeSniffer standard that enforces the Arrange-Act-Assert pattern in test code.",
  "type": "phpcodesniffer-standard",
  "license": "MIT",
  "homepage": "https://babu-ch.github.io/aaa-lint/guide/phpcs",
  "support": {
    "issues": "https://github.com/babu-ch/aaa-lint/issues",
    "source": "https://github.com/babu-ch/aaa-lint/tree/main/packages/phpcs-aaa",
    "docs": "https://babu-ch.github.io/aaa-lint/guide/phpcs"
  },
  "keywords": ["phpcs", "aaa", "arrange-act-assert", "test", "phpunit"],
  "require": {
    "php": ">=7.4",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0 || ^10.0"
  },
  "autoload-dev": {
    "psr-4": {
      "AAA\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
